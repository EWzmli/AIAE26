/* 登录页样式 - 美化版 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f9ff 0%, #fff 100%);
  position: relative;
  overflow: hidden;
}

/* 顶部装饰 */
.top-decoration {
  position: absolute;
  top: 0;
  right: 0;
  width: 300rpx;
  height: 300rpx;
  pointer-events: none;
}

.circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.1;
}

.circle-1 {
  width: 200rpx;
  height: 200rpx;
  background: #4a90e2;
  top: -50rpx;
  right: -50rpx;
}

.circle-2 {
  width: 150rpx;
  height: 150rpx;
  background: #7b68ee;
  top: 50rpx;
  right: 80rpx;
}

.circle-3 {
  width: 100rpx;
  height: 100rpx;
  background: #ff6b6b;
  top: 120rpx;
  right: 20rpx;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
  position: relative;
  z-index: 1;
}

.back-btn {
  font-size: 48rpx;
  padding: 20rpx;
  color: #333;
  transition: transform 0.2s;
}

.back-btn:active {
  transform: translateX(-10rpx);
}

/* 登录区域 */
.login-section {
  padding: 0 60rpx;
  display: flex;
  flex-direction: column;
  min-height: calc(100vh - 120rpx);
}

/* Logo区域 */
.logo-section {
  text-align: center;
  margin-top: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-circle {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 20rpx 60rpx rgba(102, 126, 234, 0.3);
  margin-bottom: 40rpx;
}

.logo-icon {
  font-size: 80rpx;
}

.logo-text {
  font-size: 56rpx;
  font-weight: 700;
  color: #1a1a2e;
  letter-spacing: 4rpx;
  margin-bottom: 16rpx;
}

.logo-subtitle {
  font-size: 32rpx;
  color: #666;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.logo-desc {
  font-size: 26rpx;
  color: #999;
}

/* 中间留白，把按钮往下推 */
.spacer {
  flex: 1;
  min-height: 100rpx;
}

/* 微信登录区域 */
.wx-login-section {
  margin-bottom: 60rpx;
}

.btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  transition: all 0.3s;
}

.btn-icon {
  font-size: 36rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #07c160 0%, #05a050 100%);
  color: #fff;
  box-shadow: 0 10rpx 40rpx rgba(7, 193, 96, 0.3);
}

.btn-primary:active {
  transform: translateY(4rpx);
  box-shadow: 0 6rpx 20rpx rgba(7, 193, 96, 0.3);
}

.btn-primary[disabled] {
  opacity: 0.7;
}

.tips-text {
  text-align: center;
  margin-top: 30rpx;
  font-size: 24rpx;
  color: #999;
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tips-text .link {
  color: #667eea;
}

/* 其他登录方式 */
.other-login-section {
  margin-bottom: 40rpx;
}

.divider {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.divider .line {
  flex: 1;
  height: 2rpx;
  background: #e0e0e0;
}

.divider-text {
  padding: 0 30rpx;
  font-size: 26rpx;
  color: #999;
}

.btn-outline {
  background: #fff;
  color: #333;
  border: 2rpx solid #e0e0e0;
}

.btn-outline:active {
  background: #f5f5f5;
}

.tips {
  margin-top: 40rpx;
  text-align: center;
}

.tips text {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

/* 开发测试入口 */
.dev-section {
  margin-bottom: 60rpx;
}

.dev-divider {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.dev-divider .line {
  flex: 1;
  height: 2rpx;
  background: #e0e0e0;
}

.dev-divider text {
  padding: 0 30rpx;
  font-size: 24rpx;
  color: #999;
}

.btn-dev {
  background: #f5f5f5;
  color: #999;
  border: 2rpx dashed #ddd;
  font-size: 28rpx;
}

.btn-dev:active {
  background: #eee;
}
