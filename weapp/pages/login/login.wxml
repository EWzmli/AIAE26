<!-- 登录页 -->
<view class="container">
  <view class="header">
    <view class="back-btn" bindtap="goBack">←</view>
    <text class="page-title">登录</text>
  </view>

  <view class="login-section">
    <view class="logo-section">
      <text class="logo-icon">🎓</text>
      <text class="logo-text">AIAE</text>
      <text class="logo-subtitle">上海交通大学创业者社区</text>
    </view>

    <view class="input-group">
      <text class="label">交大邮箱</text>
      <input 
        class="input email-full" 
        type="text" 
        placeholder="请输入交大邮箱，如 xxx@sjtu.edu.cn"
        value="{{email}}"
        bindinput="onEmailInput"
      />
    </view>

    <view class="input-group" wx:if="{{showCodeInput}}">
      <text class="label">验证码</text>
      <view class="code-input">
        <input 
          class="input" 
          type="number" 
          placeholder="请输入6位验证码"
          maxlength="6"
          value="{{verifyCode}}"
          bindinput="onCodeInput"
        />
        <button 
          class="btn-send {{countdown > 0 ? 'disabled' : ''}}" 
          bindtap="sendCode"
          disabled="{{countdown > 0 || !isValidEmail}}"
        >
          {{countdown > 0 ? countdown + 's' : '重新发送'}}
        </button>
      </view>
    </view>

    <button 
      class="btn btn-primary {{!canSubmit ? 'btn-disabled' : ''}}" 
      bindtap="submit"
      disabled="{{!canSubmit}}"
    >
      {{showCodeInput ? '登录' : '获取验证码'}}
    </button>

    <view class="divider">
      <text>或</text>
    </view>

    <button class="btn btn-outline" bindtap="jAccountLogin">
      使用 jAccount 登录
    </button>

    <view class="tips">
      <text>• 仅限上海交通大学校内用户使用</text>
      <text>• 请使用 @sjtu.edu.cn 邮箱</text>
    </view>

    <!-- 开发测试入口 -->
    <view class="dev-section" wx:if="{{isDevMode}}">
      <view class="dev-divider">
        <text>开发测试</text>
      </view>
      <button class="btn btn-dev" bindtap="devLogin">
        跳过登录（开发模式）
      </button>
    </view>
  </view>
</view>