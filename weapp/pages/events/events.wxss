.container {
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  background: #1a1a2e;
  padding: 40rpx 30rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 30rpx;
}

.filter {
  display: flex;
  gap: 20rpx;
}

.filter-item {
  padding: 12rpx 24rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #fff;
}

.filter-item.active {
  background: #fff;
  color: #1a1a2e;
}

.event-list {
  padding: 30rpx;
}

.event-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.event-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.event-type {
  background: #e8e8e8;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #666;
}

.event-date {
  font-size: 24rpx;
  color: #999;
}

.event-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.event-desc {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 20rpx;
}

.event-footer {
  display: flex;
  justify-content: space-between;
}

.event-location, .event-join {
  font-size: 24rpx;
  color: #999;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  background: #1a1a2e;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #fff;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.3);
}
