.container {
  background: #f5f5f5;
  min-height: 100vh;
}

.profile-header {
  background: #1a1a2e;
  padding: 60rpx 30rpx;
  text-align: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin: 0 auto 20rpx;
}

.name {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
}

.info {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  display: block;
  margin-bottom: 16rpx;
}

.bio {
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
  display: block;
  margin-bottom: 20rpx;
}

.tags {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.tag {
  padding: 8rpx 20rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #fff;
}

.actions {
  display: flex;
  justify-content: center;
  gap: 20rpx;
}

.link-btn, .msg-btn {
  padding: 16rpx 40rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
}

.link-btn {
  background: #fff;
  color: #1a1a2e;
}

.msg-btn {
  background: rgba(255,255,255,0.2);
  color: #fff;
}

.section {
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.post-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.post-title {
  font-size: 30rpx;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.post-time {
  font-size: 24rpx;
  color: #999;
}
