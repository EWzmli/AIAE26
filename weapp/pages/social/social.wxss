/* 社交页样式 */
.header {
  text-align: center;
  padding: 20rpx 0 40rpx;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary);
}

.subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 10rpx;
}

.card-swiper {
  height: 1000rpx;
}

.user-card {
  background: var(--card);
  border-radius: 30rpx;
  margin: 0 20rpx;
  height: 960rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: 0 10rpx 60rpx rgba(0,0,0,0.1);
}

.user-avatar {
  width: 100%;
  height: 400rpx;
  object-fit: cover;
}

.user-info {
  flex: 1;
  padding: 30rpx;
  overflow-y: auto;
}

.user-header {
  display: flex;
  align-items: baseline;
  margin-bottom: 10rpx;
}

.user-name {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text);
  margin-right: 20rpx;
}

.user-grade {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.user-major {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
}

.user-status {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.status-tag {
  padding: 8rpx 20rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 100rpx;
  font-size: 24rpx;
}

.project-name {
  font-size: 26rpx;
  color: var(--highlight);
}

.user-tags {
  margin-bottom: 20rpx;
}

.tag-section {
  margin-bottom: 16rpx;
}

.tag-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
}

.user-bio {
  background: var(--bg);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.user-bio text {
  font-size: 28rpx;
  color: var(--text);
  font-style: italic;
}

.wechat-hint {
  text-align: center;
  padding: 20rpx;
  background: var(--bg);
  border-radius: 16rpx;
}

.wechat-hint text {
  display: block;
  font-size: 28rpx;
  color: var(--text);
}

.link-hint {
  font-size: 24rpx !important;
  color: var(--text-secondary) !important;
  margin-top: 8rpx;
}

.card-actions {
  display: flex;
  gap: 30rpx;
  padding: 30rpx;
  border-top: 2rpx solid var(--border);
}

.action-btn {
  flex: 1;
  height: 90rpx;
  border-radius: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.action-btn::after {
  border: none;
}

.action-btn.skip {
  background: var(--bg);
  color: var(--text-secondary);
}

.action-btn.like {
  background: var(--highlight);
  color: #fff;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
}

.modal-content {
  position: relative;
  background: var(--card);
  border-radius: 30rpx;
  padding: 40rpx;
  width: 80%;
  max-width: 600rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 30rpx;
}

.modal-textarea {
  width: 100%;
  height: 200rpx;
  background: var(--bg);
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  margin-bottom: 30rpx;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.modal-actions .btn {
  flex: 1;
  margin: 0;
  padding: 25rpx;
  font-size: 30rpx;
}

/* 登录提示 */
.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 60rpx;
  text-align: center;
}

.prompt-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.prompt-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 20rpx;
}

.prompt-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 50rpx;
}

.btn-login {
  background: var(--primary);
  color: #fff;
  font-size: 32rpx;
  padding: 30rpx 80rpx;
  border-radius: 50rpx;
  border: none;
}

.btn-login::after {
  border: none;
}

/* 加载状态 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  font-size: 30rpx;
  color: var(--text-secondary);
}

/* 空状态 */
.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  font-size: 30rpx;
  color: var(--text-secondary);
}
