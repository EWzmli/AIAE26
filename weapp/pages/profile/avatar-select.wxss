/* pages/profile/avatar-select.wxss */
.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 140rpx;
}

/* 预览区域 */
.preview-section {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.preview-title {
  color: rgba(255, 255, 255, 0.6);
  font-size: 28rpx;
  margin-bottom: 30rpx;
}

.avatar-preview {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 6rpx solid rgba(233, 69, 96, 0.5);
  background: rgba(255, 255, 255, 0.1);
  margin-bottom: 20rpx;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.preview-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 80rpx;
  margin-bottom: 10rpx;
}

.placeholder-text {
  color: rgba(255, 255, 255, 0.5);
  font-size: 24rpx;
}

.avatar-tip {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 选项区域 */
.options-section {
  padding: 40rpx;
}

.option-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  transition: all 0.2s;
}

.option-card:active {
  transform: scale(0.98);
  background: #f9f9f9;
}

.option-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
}

.option-icon.default {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.option-icon.album {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.option-content {
  flex: 1;
}

.option-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.option-desc {
  font-size: 26rpx;
  color: #999;
}

.option-arrow {
  font-size: 40rpx;
  color: #ccc;
}

/* 说明区域 */
.info-section {
  margin: 0 40rpx;
  padding: 30rpx;
  background: rgba(233, 69, 96, 0.05);
  border-radius: 16rpx;
  border: 1rpx solid rgba(233, 69, 96, 0.1);
}

.info-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #e94560;
  margin-bottom: 16rpx;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-item {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

/* 底部按钮 */
.footer-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 30rpx 40rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 24rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.btn-cancel {
  flex: 1;
  height: 88rpx;
  background: #f5f6fa;
  color: #666;
  border-radius: 44rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-cancel::after {
  border: none;
}

.btn-save {
  flex: 2;
  height: 88rpx;
  background: linear-gradient(135deg, #e94560 0%, #ff6b6b 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-save.disabled {
  opacity: 0.5;
}

.btn-save::after {
  border: none;
}