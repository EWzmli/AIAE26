/* pages/profile/avatar-select.wxss */
.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 140rpx;
}

/* 预览区域 */
.preview-section {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.preview-title {
  color: rgba(255, 255, 255, 0.6);
  font-size: 28rpx;
  margin-bottom: 30rpx;
}

.avatar-preview {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 6rpx solid rgba(233, 69, 96, 0.5);
  background: rgba(255, 255, 255, 0.1);
}

.preview-image {
  width: 100%;
  height: 100%;
}

.preview-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 80rpx;
  margin-bottom: 10rpx;
}

.placeholder-text {
  color: rgba(255, 255, 255, 0.5);
  font-size: 24rpx;
}

/* 标签栏 */
.tab-bar {
  display: flex;
  background: #fff;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  position: relative;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #e94560;
  border-radius: 2rpx;
}

.tab-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.tab-text {
  font-size: 26rpx;
  color: #666;
}

.tab-item.active .tab-text {
  color: #e94560;
  font-weight: 500;
}

/* 内容区域 */
.content-section {
  padding: 30rpx;
}

/* 风格筛选 */
.style-filter {
  margin-bottom: 30rpx;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-list {
  display: inline-flex;
  gap: 20rpx;
}

.filter-item {
  padding: 16rpx 32rpx;
  background: #fff;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid #eee;
}

.filter-item.active {
  background: #e94560;
  color: #fff;
  border-color: #e94560;
}

/* 预设头像网格 */
.avatar-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 30rpx;
}

.avatar-item {
  display: flex;
  justify-content: center;
}

.avatar-circle {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.2s;
}

.avatar-circle:active {
  transform: scale(0.95);
}

.avatar-icon {
  font-size: 60rpx;
}

/* AI生成区域 */
.ai-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
}

.ai-description {
  text-align: center;
  margin-bottom: 40rpx;
}

.ai-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.ai-subtitle {
  font-size: 26rpx;
  color: #999;
}

.ai-input-area {
  margin-bottom: 40rpx;
}

.ai-input {
  width: 100%;
  height: 160rpx;
  background: #f5f6fa;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.ai-generate-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #e94560 0%, #ff6b6b 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.ai-generate-btn.loading {
  opacity: 0.7;
}

.ai-generate-btn::after {
  border: none;
}

/* 推荐头像 */
.generated-section {
  margin-top: 40rpx;
  padding-top: 40rpx;
  border-top: 1rpx solid #eee;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.generated-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.generated-item {
  aspect-ratio: 1;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.generated-image {
  width: 100%;
  height: 100%;
}

/* 相册区域 */
.album-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
}

.album-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  background: #f8f9fa;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  transition: all 0.2s;
}

.album-option:active {
  background: #e9ecef;
  transform: scale(0.98);
}

.option-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.option-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.option-desc {
  font-size: 26rpx;
  color: #999;
}

/* 底部按钮 */
.footer-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 30rpx 40rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 24rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.btn-cancel {
  flex: 1;
  height: 88rpx;
  background: #f5f6fa;
  color: #666;
  border-radius: 44rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-cancel::after {
  border: none;
}

.btn-save {
  flex: 2;
  height: 88rpx;
  background: linear-gradient(135deg, #e94560 0%, #ff6b6b 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-save.disabled {
  opacity: 0.5;
}

.btn-save::after {
  border: none;
}