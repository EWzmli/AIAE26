<!--pages/profile/card.wxml-->
<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">我的名片</text>
    <text class="page-subtitle">生成专属名片，用于线下交流</text>
  </view>

  <!-- 名片预览区域 -->
  <view class="card-preview-section">
    <view class="card-wrapper" bindtap="previewCard">
      <!-- 生成的名片图片 -->
      <image 
        wx:if="{{cardImage && !isGenerating}}" 
        class="card-image" 
        src="{{cardImage}}" 
        mode="widthFix"
      />
      
      <!-- 加载中 -->
      <view wx:elif="{{isGenerating}}" class="card-loading">
        <view class="loading-spinner"></view>
        <text class="loading-text">正在生成名片...</text>
      </view>
      
      <!-- 占位 -->
      <view wx:else class="card-placeholder">
        <text class="placeholder-icon">🎨</text>
        <text class="placeholder-text">点击生成名片</text>
      </view>
    </view>
    
    <!-- 提示文字 -->
    <view class="card-hint" wx:if="{{cardImage}}">
      <text class="hint-text">点击名片可预览大图</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-section" wx:if="{{showActions}}">
    <view class="action-grid">
      <view class="action-item" bindtap="saveCard">
        <view class="action-icon save">💾</view>
        <text class="action-text">保存</text>
      </view>
      
      <view class="action-item" bindtap="printCard">
        <view class="action-icon print">🖨️</view>
        <text class="action-text">打印</text>
      </view>
      
      <button class="action-item share-btn" open-type="share">
        <view class="action-icon share">📤</view>
        <text class="action-text">分享</text>
      </button>
    </view>
  </view>

  <!-- 提示信息 -->
  <view class="tips-section">
    <text class="tips-icon">💡</text>
    <text class="tips-text">名片信息来自个人资料，编辑资料可更新名片内容</text>
  </view>

  <!-- 隐藏的画布 -->
  <canvas type="2d" id="cardCanvas" style="position: fixed; left: -9999px; top: -9999px;"></canvas>
</view>