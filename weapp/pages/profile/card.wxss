/* 名片页面样式 */
.container {
  padding: 30rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.card-preview {
  margin-bottom: 40rpx;
}

.business-card {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  color: #fff;
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.2);
}

.card-header {
  border-bottom: 1rpx solid rgba(255,255,255,0.1);
  padding-bottom: 20rpx;
  margin-bottom: 30rpx;
}

.card-logo {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
}

.card-subtitle {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
}

.card-body {
  display: flex;
  align-items: flex-start;
  margin-bottom: 30rpx;
}

.user-avatar-large {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 30rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.user-grade-major {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  display: block;
  margin-bottom: 15rpx;
}

.status-badge {
  display: inline-block;
  background: #4CAF50;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-bottom: 15rpx;
}

.user-bio {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  line-height: 1.5;
  display: block;
}

.card-footer {
  border-top: 1rpx solid rgba(255,255,255,0.1);
  padding-top: 20rpx;
}

.tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 15rpx;
}

.mini-tag {
  background: rgba(255,255,255,0.2);
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
}

.card-tip {
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
  text-align: center;
  display: block;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.action-buttons .btn {
  flex: 1;
  margin: 0;
}

.btn-primary {
  background: #1a1a2e;
  color: #fff;
  border-radius: 40rpx;
  padding: 30rpx 0;
  font-size: 30rpx;
  border: none;
}

.btn-outline {
  background: #fff;
  color: #1a1a2e;
  border: 2rpx solid #1a1a2e;
  border-radius: 40rpx;
  padding: 28rpx 0;
  font-size: 30rpx;
}

.btn-primary::after, .btn-outline::after {
  border: none;
}

.tips {
  text-align: center;
  padding: 20rpx;
}

.tips text {
  font-size: 24rpx;
  color: #999;
}
