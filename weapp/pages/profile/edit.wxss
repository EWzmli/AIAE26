/* pages/profile/edit.wxss */
.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 160rpx;
}

/* 头像区域 */
.avatar-section {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-wrapper {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 6rpx solid rgba(233, 69, 96, 0.5);
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  background: #e94560;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-text {
  font-size: 80rpx;
  color: #fff;
  font-weight: 600;
}

.avatar-edit {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 60rpx;
  height: 60rpx;
  background: #e94560;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #fff;
}

.edit-icon {
  font-size: 28rpx;
}

.avatar-tip {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 表单区域 */
.form-section {
  padding: 30rpx;
}

.form-group {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.group-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
}

.group-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.add-btn {
  font-size: 26rpx;
  color: #e94560;
  padding: 8rpx 16rpx;
}

.form-item {
  margin-bottom: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  padding-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
  border-bottom: none;
  padding-bottom: 0;
}

.textarea-item {
  position: relative;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.label.required::after {
  content: '*';
  color: #e94560;
  margin-left: 8rpx;
}

input, .picker {
  font-size: 30rpx;
  color: #333;
  height: 60rpx;
  line-height: 60rpx;
}

.picker.placeholder {
  color: #999;
}

textarea {
  width: 100%;
  height: 160rpx;
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
}

.textarea-count {
  position: absolute;
  bottom: 0;
  right: 0;
  font-size: 24rpx;
  color: #999;
}

/* 状态标签 */
.status-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.status-tag {
  padding: 16rpx 28rpx;
  background: #f5f6fa;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.status-tag.active {
  background: rgba(233, 69, 96, 0.1);
  color: #e94560;
  border-color: #e94560;
}

/* 标签列表 */
.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  min-height: 80rpx;
}

.tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
}

.tech-tag {
  background: rgba(233, 69, 96, 0.1);
  color: #e94560;
}

.interest-tag {
  background: rgba(78, 205, 196, 0.1);
  color: #4ecdc4;
}

.tag-remove {
  font-size: 24rpx;
  opacity: 0.6;
  padding: 0 4rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #999;
  padding: 20rpx 0;
}

/* 底部按钮 */
.footer-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 30rpx 40rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 24rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.btn-cancel {
  flex: 1;
  height: 88rpx;
  background: #f5f6fa;
  color: #666;
  border-radius: 44rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-cancel::after {
  border: none;
}

.btn-save {
  flex: 2;
  height: 88rpx;
  background: linear-gradient(135deg, #e94560 0%, #ff6b6b 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-save::after {
  border: none;
}