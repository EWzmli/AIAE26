<!--pages/profile/edit.wxml-->
<view class="container">
  <!-- 头像区域 -->
  <view class="avatar-section" bindtap="selectAvatar">
    <view class="avatar-wrapper">
      <image 
        wx:if="{{userInfo.avatar || tempAvatar}}" 
        class="avatar-image" 
        src="{{tempAvatar || userInfo.avatar}}" 
        mode="aspectFill"
      />
      <view wx:else class="avatar-placeholder" style="background: {{userInfo.name ? '' : '#e94560'}};">
        <text class="placeholder-text">{{nameInitials}}</text>
      </view>
      <view class="avatar-edit">
        <text class="edit-icon">📷</text>
      </view>
    </view>
    <text class="avatar-tip">点击更换头像</text>
  </view>

  <!-- 表单区域 -->
  <view class="form-section">
    <!-- 基本信息 -->
    <view class="form-group">
      <view class="group-title">基本信息</view>
      
      <view class="form-item">
        <text class="label required">昵称</text>
        <input 
          type="text" 
          placeholder="请输入昵称" 
          value="{{userInfo.nickname}}" 
          bindinput="onNicknameInput"
        />
      </view>
      
      <view class="form-item">
        <text class="label required">真实姓名</text>
        <input 
          type="text" 
          placeholder="请输入真实姓名" 
          value="{{userInfo.name}}" 
          bindinput="onNameInput"
        />
      </view>
      
      <view class="form-item">
        <text class="label required">年级</text>
        <picker bindchange="onGradeChange" value="{{gradeIndex}}" range="{{grades}}">
          <view class="picker {{userInfo.grade ? '' : 'placeholder'}}">
            {{userInfo.grade || '请选择年级'}}
          </view>
        </picker>
      </view>
      
      <view class="form-item">
        <text class="label required">专业</text>
        <input 
          type="text" 
          placeholder="请输入专业" 
          value="{{userInfo.major}}" 
          bindinput="onMajorInput"
        />
      </view>
    </view>

    <!-- 联系方式 -->
    <view class="form-group">
      <view class="group-title">联系方式</view>
      
      <view class="form-item">
        <text class="label required">微信号</text>
        <input 
          type="text" 
          placeholder="用于名片展示" 
          value="{{userInfo.wechatId}}" 
          bindinput="onWechatInput"
        />
      </view>
    </view>

    <!-- 创业信息 -->
    <view class="form-group">
      <view class="group-title">创业信息</view>
      
      <view class="form-item">
        <text class="label required">当前状态</text>
        <view class="status-tags">
          <view 
            wx:for="{{statusTags}}" 
            wx:key="*this"
            class="status-tag {{userInfo.statusTag === item ? 'active' : ''}}"
            bindtap="selectStatusTag"
            data-tag="{{item}}"
          >
            {{item}}
          </view>
        </view>
      </view>
      
      <view class="form-item">
        <text class="label">项目/公司名</text>
        <input 
          type="text" 
          placeholder="如果有创业项目请填写" 
          value="{{userInfo.projectName}}" 
          bindinput="onProjectInput"
        />
      </view>
    </view>

    <!-- 个人简介 -->
    <view class="form-group">
      <view class="group-title">个人简介</view>
      
      <view class="form-item textarea-item">
        <textarea 
          placeholder="介绍你自己，让更多人了解你..." 
          value="{{userInfo.bio}}" 
          bindinput="onBioInput"
          maxlength="200"
        />
        <text class="textarea-count">{{bioLength}}/200</text>
      </view>
    </view>

    <!-- 技能标签 -->
    <view class="form-group">
      <view class="group-header">
        <text class="group-title">技能标签</text>
        <text class="add-btn" bindtap="addTechTag">+ 添加</text>
      </view>
      
      <view class="tags-list">
        <view 
          wx:for="{{userInfo.techTags}}" 
          wx:key="index"
          class="tag tech-tag"
        >
          <text>{{item}}</text>
          <text class="tag-remove" bindtap="removeTechTag" data-index="{{index}}">×</text>
        </view>
        <text wx:if="{{!userInfo.techTags || userInfo.techTags.length === 0}}" class="empty-tip">添加技能标签，方便他人找到你</text>
      </view>
    </view>

    <!-- 兴趣标签 -->
    <view class="form-group">
      <view class="group-header">
        <text class="group-title">兴趣标签</text>
        <text class="add-btn" bindtap="addInterestTag">+ 添加</text>
      </view>
      
      <view class="tags-list">
        <view 
          wx:for="{{userInfo.interestTags}}" 
          wx:key="index"
          class="tag interest-tag"
        >
          <text>{{item}}</text>
          <text class="tag-remove" bindtap="removeInterestTag" data-index="{{index}}">×</text>
        </view>
        <text wx:if="{{!userInfo.interestTags || userInfo.interestTags.length === 0}}" class="empty-tip">添加兴趣标签，找到志同道合的伙伴</text>
      </view>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="footer-actions">
    <button class="btn-cancel" bindtap="cancel">取消</button>
    <button class="btn-save" bindtap="saveProfile">保存</button>
  </view>
</view>