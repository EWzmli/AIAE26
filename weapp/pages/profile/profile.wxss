/* 个人中心样式 */
.user-card {
  padding: 40rpx;
}

.user-main {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.user-details {
  margin-left: 30rpx;
  flex: 1;
}

.user-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text);
}

.user-meta {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-top: 10rpx;
}

.status-tag {
  display: inline-block;
  margin-top: 16rpx;
  padding: 8rpx 20rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 100rpx;
  font-size: 24rpx;
}

.user-stats {
  display: flex;
  justify-content: space-around;
  padding-top: 40rpx;
  border-top: 2rpx solid var(--border);
}

.stat-item {
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary);
}

.stat-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
}

.edit-btn {
  font-size: 28rpx;
  color: var(--highlight);
}

.tag-section {
  margin-bottom: 24rpx;
}

.tag-section:last-child {
  margin-bottom: 0;
}

.bio-text {
  font-size: 30rpx;
  color: var(--text);
  line-height: 1.6;
}

/* 菜单 */
.menu-card {
  padding: 0;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid var(--border);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--text);
}

.menu-arrow {
  font-size: 36rpx;
  color: var(--text-secondary);
}

.logout-btn {
  margin-top: 40rpx;
  margin-bottom: 60rpx;
}
