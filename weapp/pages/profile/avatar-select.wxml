<!--pages/profile/avatar-select.wxml-->
<view class="container">
  <!-- 预览区域 -->
  <view class="preview-section">
    <view class="preview-title">头像预览</view>
    <view class="avatar-preview" bindtap="previewAvatar">
      <image wx:if="{{customAvatar}}" class="preview-image" src="{{customAvatar}}" mode="aspectFill"/>
      <view wx:else class="preview-placeholder">
        <text class="placeholder-icon">👤</text>
        <text class="placeholder-text">生成中...</text>
      </view>
    </view>
    <text class="avatar-tip">点击预览大图</text>
  </view>

  <!-- 选项区域 -->
  <view class="options-section">
    <view class="option-card" bindtap="generateDefaultAvatar">
      <view class="option-icon default">🎨</view>
      <view class="option-content">
        <text class="option-title">使用默认头像</text>
        <text class="option-desc">根据您的姓名自动生成</text>
      </view>
      <text class="option-arrow">›</text>
    </view>

    <view class="option-card" bindtap="chooseFromAlbum">
      <view class="option-icon album">📷</view>
      <view class="option-content">
        <text class="option-title">从相册选择</text>
        <text class="option-desc">使用自己喜欢的照片</text>
      </view>
      <text class="option-arrow">›</text>
    </view>
  </view>

  <!-- 说明文字 -->
  <view class="info-section">
    <text class="info-title">💡 默认头像规则</text>
    <view class="info-list">
      <text class="info-item">• 中文姓名：显示后两位（如"张三丰"→"三丰"）</text>
      <text class="info-item">• 英文姓名：显示首字母（如"David Jack"→"DJ"）</text>
      <text class="info-item">• 颜色根据姓名自动匹配</text>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="footer-actions">
    <button class="btn-cancel" bindtap="cancel">取消</button>
    <button class="btn-save {{!customAvatar ? 'disabled' : ''}}" bindtap="saveAvatar">保存头像</button>
  </view>
</view>

<!-- 隐藏的Canvas用于生成图片 -->
<canvas type="2d" id="avatarCanvas" style="position: fixed; left: -9999px; top: -9999px;"></canvas>