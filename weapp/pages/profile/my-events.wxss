/* 我的活动样式 */
.container {
  padding: 30rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 150rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.btn-explore {
  background: #1a1a2e;
  color: #fff;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

.event-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.event-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.event-info {
  display: flex;
  margin-bottom: 20rpx;
}

.event-poster {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background: #f0f0f0;
}

.event-detail {
  flex: 1;
}

.event-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.event-time, .event-location {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 6rpx;
}

.reg-status {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-top: 10rpx;
}

.reg-status.registered {
  background: #e8f5e9;
  color: #4CAF50;
}

.reg-status.checked_in {
  background: #e3f2fd;
  color: #2196F3;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
  font-size: 26rpx;
  padding: 16rpx 0;
  border-radius: 8rpx;
  border: none;
}

.btn-cancel::after {
  border: none;
}
