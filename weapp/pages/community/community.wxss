/* 社区页样式 */
.tab-bar {
  display: flex;
  background: var(--card);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx;
  font-size: 30rpx;
  color: var(--text-secondary);
  position: relative;
}

.tab-item.active {
  color: var(--primary);
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: var(--highlight);
  border-radius: 2rpx;
}

.filter-bar {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.filter-item {
  background: var(--card);
  padding: 20rpx 30rpx;
  border-radius: 100rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  display: flex;
  align-items: center;
}

.filter-item .arrow {
  margin-left: 10rpx;
  font-size: 20rpx;
}

/* 帖子卡片 */
.post-card {
  background: var(--card);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.post-meta {
  flex: 1;
  margin-left: 20rpx;
}

.username {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text);
}

.time {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.post-type {
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
  font-size: 24rpx;
}

.type-partner {
  background: rgba(233, 69, 96, 0.1);
  color: var(--highlight);
}

.type-job {
  background: rgba(26, 26, 46, 0.08);
  color: var(--primary);
}

.post-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 16rpx;
}

.post-content {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.post-tags {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.post-footer {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid var(--border);
}

.project-name, .reward {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 活动卡片 */
.event-card {
  background: var(--card);
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.event-poster {
  width: 100%;
  height: 300rpx;
}

.event-info {
  padding: 30rpx;
}

.event-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 20rpx;
}

.event-meta {
  margin-bottom: 16rpx;
}

.event-meta text {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
}

.event-organizer {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
}

.event-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 2rpx solid var(--border);
}

.event-type {
  padding: 8rpx 20rpx;
  background: var(--bg);
  border-radius: 100rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.participant-count {
  font-size: 26rpx;
  color: var(--highlight);
}

/* 发布按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 140rpx;
  width: 140rpx;
  height: 140rpx;
  background: var(--highlight);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(233, 69, 96, 0.4);
}

.fab-icon {
  font-size: 48rpx;
  font-weight: 300;
  line-height: 1;
}
