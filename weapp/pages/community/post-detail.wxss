.container {
  padding: 30rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.post-header {
  margin-bottom: 30rpx;
}

.author-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  background: #1a1a2e;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #fff;
  margin-right: 20rpx;
}

.author-meta {
  display: flex;
  flex-direction: column;
}

.author-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.post-time {
  font-size: 24rpx;
  color: #999;
}

.post-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.post-content {
  font-size: 30rpx;
  color: #666;
  line-height: 1.8;
  display: block;
  margin-bottom: 30rpx;
}

.post-actions {
  display: flex;
  gap: 40rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid #e8e8e8;
  border-bottom: 1rpx solid #e8e8e8;
  margin-bottom: 30rpx;
}

.action {
  font-size: 28rpx;
  color: #666;
}

.comments-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.comment {
  display: flex;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.comment-avatar {
  width: 60rpx;
  height: 60rpx;
  background: #e8e8e8;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  margin-right: 16rpx;
}

.comment-content {
  flex: 1;
}

.comment-author {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.comment-text {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin: 8rpx 0;
}

.comment-time {
  font-size: 22rpx;
  color: #999;
}
