/**app.wxss**/
/* 全局样式 */
page {
  --primary: #1a1a2e;
  --primary-light: #16213e;
  --accent: #0f3460;
  --highlight: #e94560;
  --bg: #f5f5f7;
  --card: #ffffff;
  --text: #1a1a2e;
  --text-secondary: #666;
  --border: #e0e0e0;
  
  background-color: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  color: var(--text);
}

/* 通用容器 */
.container {
  padding: 30rpx;
}

/* 卡片样式 */
.card {
  background: var(--card);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 20rpx rgba(0,0,0,0.05);
}

/* 按钮样式 */
.btn {
  background: var(--primary);
  color: #fff;
  border-radius: 100rpx;
  padding: 30rpx 60rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: var(--highlight);
}

.btn-outline {
  background: transparent;
  border: 2rpx solid var(--primary);
  color: var(--primary);
}

.btn-disabled {
  opacity: 0.5;
}

/* 输入框样式 */
.input {
  background: var(--bg);
  border-radius: 16rpx;
  padding: 30rpx;
  font-size: 30rpx;
  margin-bottom: 20rpx;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 12rpx 24rpx;
  background: rgba(26, 26, 46, 0.08);
  border-radius: 100rpx;
  font-size: 24rpx;
  margin: 0 10rpx 10rpx 0;
}

.tag-active {
  background: var(--primary);
  color: #fff;
}

.tag-skill {
  background: rgba(233, 69, 96, 0.1);
  color: var(--highlight);
}

/* Flex布局 */
.flex {
  display: flex;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 文本 */
.text-center {
  text-align: center;
}

.text-secondary {
  color: var(--text-secondary);
}

.text-highlight {
  color: var(--highlight);
}

.font-bold {
  font-weight: 600;
}

/* 间距 */
.mt-20 { margin-top: 20rpx; }
.mt-40 { margin-top: 40rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-40 { margin-bottom: 40rpx; }

/* 头像 */
.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  object-fit: cover;
}

.avatar-lg {
  width: 180rpx;
  height: 180rpx;
}

.avatar-sm {
  width: 80rpx;
  height: 80rpx;
}

/* 分割线 */
.divider {
  height: 2rpx;
  background: var(--border);
  margin: 30rpx 0;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 60rpx;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.3;
}

.empty-state text {
  display: block;
  margin-top: 30rpx;
  color: var(--text-secondary);
}
