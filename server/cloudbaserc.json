{
  "version": "2.0",
  "envId": "cloudbase-6g3e4gx180dae419",
  "framework": {
    "name": "aiae-server",
    "plugins": {
      "server": {
        "use": "@cloudbase/framework-plugin-container",
        "inputs": {
          "serviceName": "aiae-server",
          "servicePath": "/",
          "containerPort": 3000,
          "dockerfilePath": "./Dockerfile",
          "minNum": 0,
          "maxNum": 10,
          "cpu": 0.25,
          "mem": 0.5,
          "policyType": "cpu",
          "policyThreshold": 60,
          "envVariables": {
            "NODE_ENV": "production",
            "JWT_SECRET": "aiae_production_secret_key_2026",
            "PORT": "3000"
          }
        }
      }
    }
  }
}